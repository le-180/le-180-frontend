---
import fetchApi from '../../lib/strapi';
import type Artikel from '../../interfaces/artikel';
import Layout from '../../layouts/Layout.astro';

const articles = await fetchApi<Artikel[]>({
  endpoint: 'texts',
  wrappedByKey: 'data',
  query: { populate: '*' },
});

const articleList = articles.map((article) => {
  return {
    title: article.title,
    url: article.id,
    authors: article.authors,
  };
});
console.log('Artikel Liste', JSON.stringify(articleList));
---

<Layout>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <ul>
      {
        articleList.map((article) => (
          <li class="border-b-2">
            <a href={`/artikel/${article.url}/`}>{article.title}</a> von{' '}
            {article.authors.map((author) => `${author.vorname} ${author.nachname}`)}
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
